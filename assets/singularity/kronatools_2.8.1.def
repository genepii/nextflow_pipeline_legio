Bootstrap: docker
From: ubuntu:22.04

%labels
    Author nextflow_pipeline_legio
    Tool Krona
    Version 2.8.1
    Build HPC-safe true

%help
    KronaTools 2.8.1 HPC-safe installation for Singularity/Apptainer.
    Fixes Perl library path and permission issues.

%environment
    export LC_ALL=C
    export LANG=C

    export KRONA_ROOT=/opt/KronaTools
    export PATH=$KRONA_ROOT/scripts:$KRONA_ROOT/bin:$PATH
    export PERL5LIB=$KRONA_ROOT/lib:$KRONA_ROOT/scripts:$PERL5LIB

%post
    set -eux

    apt-get update && apt-get install -y \
        perl \
        wget \
        make \
        gcc \
        tar \
        gzip \
        ca-certificates

    cd /opt

    wget -q https://github.com/marbl/Krona/releases/download/v2.8.1/KronaTools-2.8.1.tar

    tar --no-same-owner --no-same-permissions -xf KronaTools-2.8.1.tar

    mv KronaTools-2.8.1 KronaTools

    cd KronaTools

    perl install.pl

    chmod -R a+rX /opt/KronaTools

    find /opt/KronaTools -type f -name "*.pl" -exec chmod +x {} \;
    find /opt/KronaTools -type f -name "*.sh" -exec chmod +x {} \;

    # Taxonomy DB
    ./updateTaxonomy.sh || true

    # Cleanup
    rm -f /opt/KronaTools-2.8.1.tar

%runscript
    exec "$@"

%test
    set -eux

    # check Perl module access (IMPORTANT FIX TEST)
    perl -e 'use lib "/opt/KronaTools/lib"; use KronaTools; print "OK\n"'

    # check binary availability
    ktImportText 2>&1 | head -n 1 || true

    echo "Krona HPC-safe OK"