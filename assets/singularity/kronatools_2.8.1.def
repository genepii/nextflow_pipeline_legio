Bootstrap: docker
From: ubuntu:22.04

%labels
    Author nextflow_pipeline_legio
    Tool Krona
    Version 2.8.1
    Build reproducible true
    Source github-marbl

%environment
    export LC_ALL=C
    export LANG=C
    export PATH=/opt/KronaTools/bin:$PATH

%post
    apt-get update && apt-get install -y \
        perl \
        wget \
        make \
        gcc \
        tar \
        gzip \
        ca-certificates

    cd /opt

    wget https://github.com/marbl/Krona/releases/download/v2.8.1/KronaTools-2.8.1.tar

    tar -xf KronaTools-2.8.1.tar
    cd KronaTools-2.8.1

    ./install.pl

    # Taxonomy DB fix (versioned snapshot possible)
    ktUpdateTaxonomy.sh

    apt-get clean && rm -rf /var/lib/apt/lists/*

%runscript
    exec "$@"

%test
    ktImportText --help