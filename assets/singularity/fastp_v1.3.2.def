Bootstrap: docker
From: quay.io/biocontainers/fastp:1.3.2--h43da1c4_0

%labels
    Author nextflow_pipeline_legio
    Version fastp 1.3.2
    Build reproducible true

%help
    Singularity image for FASTQ quality filtering (fastp 1.3.2).

%environment
    export LC_ALL=C
    export LANG=C
    export OMP_NUM_THREADS=1

%runscript
    exec fastp "$@"

%test
    fastp --version