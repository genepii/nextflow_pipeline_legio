singularity {
    enabled = true
    autoMounts = true               //if false, workdir not found
    runOptions = "--bind ${HOME}"   //needed for matplotlib cache
}

executor {
  local {
      queueSize = 16
      cpus = 16
      memory = "600 GB"
  }
}

process {
    withLabel: "cutadapt" {
        container = "/srv/scratch/iai/bachcl/singularity/cutadapt_5.2.sif"
        maxForks = 2
        cpus = 8
        memory = 100.GB
        errorStrategy = { task.exitStatus == 255 ? 'retry' : 'terminate' }
        maxRetries = 5  
    }
    withLabel: "qiime" {
        container = "/srv/scratch/iai/bachcl/singularity/qiime2-amplicon_krona_2024.10.sif"
        maxForks = 4
        cpus = 4
        memory = 75.GB
        errorStrategy = { task.exitStatus == 255 ? 'retry' : 'terminate' }
        maxRetries = 5  
    }
}

params {
    // Notes : Settings below are set by the `start_qiime2.sh` script; 
    //         values shown are indicative only and apply if the script is run directly. 
    
    def sequencing_id = "YYYYMMDD"              //locally a date
    def analyse_ID = new Date().format('yyyyMMdd')
    
    suffix = "${sequencing_id}"                 //suffix for output files

    input_dir = "/srv/net/cluqumngs/BDD_COMMUN/Illumina/FASTQ/Legionella-Amplicons-${sequencing_id}"        //input folder
    workDir = "/srv/scratch/iai/bachcl/result/Legionella/23S-5S/${sequencing_id}/${analyse_ID}/work"        //working directory
    result = "/srv/scratch/iai/bachcl/result/Legionella/23S-5S/${sequencing_id}/${analyse_ID}"              //output folder

    paired_end = true                           //analysis paths choice
    all_in_one = true
    trimming = false


    // -------------------------------------------------------------------------
    // Notes : Settings below are set by the `qiime2.config` file.
    // Parameters for trimming with Cutadapt
    min_quality = 30
    min_length = 50

    // Parameters for denoising with Dada2
    trim_left_f = 0                             //not used
    trim_left_r = 0                             //not used
    trunc_len_f = 148                           //if SE only trunc_len_f used
    trunc_len_r = 148
    n_threads = 15
    reads_learn = 500000                        //error model
    fold_parents = 2

    // Parameters for classifier training
    db = "23s5sdb_V2.0.0"
    reads = "/srv/scratch/iai/bachcl/nextflow_pipeline_legio/data/Merge_23S-5S_20260312_pub.fasta"
    taxa =  "/srv/scratch/iai/bachcl/nextflow_pipeline_legio/data/23s5sdb_V2.0.0.tax"

    // Parameters for taxonomic classification
    confidence = 0.99
    n_jobs = 3
}



// -----------------------------------------------------------------------------
profiles {
    // Profile used during pipeline developping by A. PETICCA, do not touch
    test {
        def baseDir = "/srv/scratch/peticcaau/test"

        process.executor = 'local'
        workDir = "${baseDir}/work"

        params {
            suffix = "test"
             
            input_dir = "/home/chu-lyon.fr/peticcaau/Tmp_HCL/data/reads" 
            result = "${baseDir}/results"

            paired_end = true
            all_in_one = true
            trimming = false

            min_quality = 30
            min_length = 50

            trunc_len_f = 148
            trunc_len_r = 148
            n_threads = 15
            reads_learn = 50
            fold_parents = 2

            db = "23s5sdb_V2.0.0"
            reads = "/home/chu-lyon.fr/peticcaau/Tmp_HCL/data/db/Merge_23S-5S_20260312_pub.fasta"
            taxa =  "/home/chu-lyon.fr/peticcaau/Tmp_HCL/data/db/23s5sdb_V2.0.0.tax"

            confidence = 0.99
            n_jobs = 3
        }
    }
}